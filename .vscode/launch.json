{
    "version": "0.2.0",
    "configurations": [        
        {
            "name": "Python Debugger: Flask App",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "env": {
                "FLASK_APP": "app.py",
                "FLASK_DEBUG": "1"
            },
            "args": [
                "run",
                "--no-debugger",
                "--no-reload"
            ],
            "jinja": true,
            "cwd": "${workspaceFolder}/src",
            "justMyCode": true
        }
    ]
}
